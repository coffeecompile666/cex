# Server Configuration
PORT=8080

# Database Configuration (PostgreSQL example)
# Replace with your actual database credentials
DATABASE_URL=host=localhost user=postgres password=postgres dbname=icon_exchange port=5432 sslmode=disable TimeZone=Asia/Ho_Chi_Minh

# Environment
GIN_MODE=debug # set to release in production

# Auth / JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY_MINUTES=15

# Refresh Token
REFRESH_TOKEN_MASTER_KEY=change-me-to-another-long-random-secret

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
